ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite


LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=moveops

# 카카오 T 퀵·도보 배송 Sandbox
# 권장 키 이름
KAKAO_MOBILITY_API_KEY=
KAKAO_MOBILITY_VENDOR_ID=
KAKAO_MOBILITY_BASE_URL=https://open-api-logistics.kakaomobility.com
KAKAO_MOBILITY_CALLBACK_BASE_URL=
KAKAO_MOBILITY_TIMEOUT_SECONDS=10
KAKAO_MOBILITY_DATABASE_PATH=mobility_service/data/mobility.db

# 레거시 키 이름(기존 .env 호환). 둘 중 하나만 채워도 됩니다.
KakaoMobility_API=
Vendor_ID=

# 카카오 지도 JavaScript SDK
# 카카오 디벨로퍼스에서 등록한 웹 도메인과 연결된 JavaScript 키를 사용합니다.
# KAKAO_MAP_KEY는 과거 이름(별칭)입니다. 혼동 방지를 위해 같은 값으로 맞추거나 비워두세요.
KAKAO_JAVASCRIPT_KEY=

# 최초 관리자 계정 — 실제 값은 .env에만 저장하세요.
MOVB_ADMIN_USERNAME=
MOVB_ADMIN_PASSWORD=
KAKAO_MAP_KEY=

# 카카오 로컬(Local) REST API — 배송 도우미 챗봇이 주소를 좌표로 변환할 때 사용
# (지도 JavaScript 키와는 별개의 키. 서버에서만 쓰고 클라이언트로 노출하지 않습니다.)
KAKAO_REST_API_KEY=
KAKAO_DIRECTIONS_BASE_URL=https://apis-navi.kakaomobility.com

# 카카오 앱 참고용 (현재 서버 코드에서 직접 사용하지 않음)
KAKAO_NATIVE_APP_KEY=

# '내 로컬 채팅' 모드 — Ollama (사용 전 `ollama serve` 실행 필요)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_SECONDS=120
