ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# LangSmith 관측(선택): true이면 질문, 검색 문서, 답변 trace가 LangSmith로 전송된다.
# 민감한 문서나 개인정보가 있는 환경에서는 false를 유지한다.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=leon-rag-chatbot
# 여러 workspace에 연결된 키라면 설정:
# LANGSMITH_WORKSPACE_ID=
# 한국 리전(APAC) 계정이라면 설정:
# LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com

# 로컬 임베딩 실행 기본값
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# 임베딩 모델은 기본적으로 로컬 캐시만 사용한다.
# 처음 다운로드/인덱싱할 때만 0으로 바꿔 실행한다.
# RAG_EMBEDDING_CACHE_DIR를 비워두면 Hugging Face 기본 캐시를 사용한다.
RAG_EMBEDDINGS_LOCAL_ONLY=1
# RAG_EMBEDDING_CACHE_DIR=artifacts/hf_cache

# Qwen 로컬 추론 / LoRA / 양자화 옵션
QWEN_LOCAL_MODEL=Qwen/Qwen2.5-0.5B-Instruct
QWEN_LORA_ADAPTER=artifacts/lora_adapter
# QWEN_QUANT=4bit
