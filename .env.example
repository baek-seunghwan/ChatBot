ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite


LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=leon-rag-chatbot


HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1


RAG_EMBEDDINGS_LOCAL_ONLY=1

# chroma / faiss / bm25 중 하나 또는 쉼표로 여러 개 지정
RAG_RETRIEVAL_BACKENDS=chroma,faiss,bm25
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
RAG_MIN_RELEVANCE_SCORE=0.35
RAG_CHROMA_WEIGHT=0.25
RAG_FAISS_WEIGHT=0.25
RAG_BM25_WEIGHT=0.50

# 카카오 T 퀵·도보 배송 Sandbox
# 기존에 사용하는 KakaoMobility_API / Vendor_ID 이름도 앱에서 지원합니다.
KAKAO_MOBILITY_API_KEY=
KAKAO_MOBILITY_VENDOR_ID=
KAKAO_MOBILITY_BASE_URL=https://open-api-logistics.kakaomobility.com
KAKAO_MOBILITY_CALLBACK_BASE_URL=

# 카카오 지도 JavaScript SDK
# 카카오 디벨로퍼스에서 등록한 웹 도메인과 연결된 JavaScript 키를 사용합니다.
KAKAO_JAVASCRIPT_KEY=

# 카카오 로컬(Local) REST API — 배송 도우미 챗봇이 주소를 좌표로 변환할 때 사용
# (지도 JavaScript 키와는 별개의 키. 서버에서만 쓰고 클라이언트로 노출하지 않습니다.)
KAKAO_REST_API_KEY=
